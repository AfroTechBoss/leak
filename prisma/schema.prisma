generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Journalist {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  name         String
  newsroom     String
  createdAt    DateTime      @default(now()) @map("created_at")
  submissions  Submission[]
  messages     Message[]
  auditLogs    AuditLog[]

  @@map("journalists")
}

model Submission {
  id              String      @id @default(cuid())
  caseCodeHash    String      @unique @map("case_code_hash")
  category        String
  state           String
  encryptedBody   Bytes       @map("encrypted_body")
  encryptedNonce  Bytes       @map("encrypted_nonce")
  status          Status      @default(NEW)
  newsroom        String
  journalist      Journalist? @relation(fields: [journalistId], references: [id])
  journalistId    String?     @map("journalist_id")
  files           File[]
  messages        Message[]
  auditLogs       AuditLog[]
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@map("submissions")
}

model File {
  id           String     @id @default(cuid())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String     @map("submission_id")
  originalName String     @map("original_name")
  storageKey   String     @map("storage_key")
  mimeType     String     @map("mime_type")
  sizeBytes    Int        @map("size_bytes")
  strippedAt   DateTime?  @map("stripped_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("files")
}

model Message {
  id              String     @id @default(cuid())
  submission      Submission @relation(fields: [submissionId], references: [id])
  submissionId    String     @map("submission_id")
  sender          Sender
  encryptedBody   Bytes      @map("encrypted_body")
  encryptedNonce  Bytes      @map("encrypted_nonce")
  journalist      Journalist? @relation(fields: [journalistId], references: [id])
  journalistId    String?    @map("journalist_id")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("messages")
}

model AuditLog {
  id           String     @id @default(cuid())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String     @map("submission_id")
  journalist   Journalist? @relation(fields: [journalistId], references: [id])
  journalistId String?    @map("journalist_id")
  action       String
  ipHash       String?    @map("ip_hash")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@map("audit_logs")
}

enum Status {
  NEW
  UNDER_REVIEW
  INVESTIGATION_OPENED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum Sender {
  WHISTLEBLOWER
  JOURNALIST
  SYSTEM
}
